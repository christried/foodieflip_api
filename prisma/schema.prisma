// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RecipeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String   @id @default(cuid())
  googleSub        String   @unique
  email            String   @unique
  username         String?  @unique
  role             UserRole @default(USER)
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  submittedRecipes Recipe[] @relation("SubmittedRecipes")
}

model Recipe {
  id             String       @id @default(cuid())
  title          String
  shortTitle     String       @unique
  time           Int
  imageExtension String @default("jpg")
  imageAlt       String
  ingredients    String[]
  instructions   String[]
  tagsPublic     String[]
  tagsInternal   String[]
  upvotes        Int          @default(0)
  downvotes      Int          @default(0)
  submittedBy    String       @default("FoodieFlip")
  submittedByUserId String?
  submittedByUser User? @relation("SubmittedRecipes", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  status         RecipeStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([submittedByUserId])
}